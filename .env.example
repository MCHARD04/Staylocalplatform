# ════════════════════════════════════════════════════════
#   STAYLOCAL - ENVIRONMENT VARIABLES
#   Copy this file to .env and fill in your real values
#   Command: copy .env.example .env
# ════════════════════════════════════════════════════════

# ─── SERVER ──────────────────────────────────────────────
PORT=3001

# ─── FLUTTERWAVE PAYMENT GATEWAY ──────────────────────────
#
# HATUA ZA KUPATA CREDENTIALS:
# ─────────────────────────────
# 1. Nenda: https://dashboard.flutterwave.com/signup
# 2. Jisajili (hauhitaji approval - test keys zinafanya kazi mara moja)
# 3. Login, nenda: Settings > API Keys
# 4. Nakili "Test Secret Key" (huanza na FLWSECK_TEST-)
# 5. Nakili "Test Public Key" (huanza na FLWPUBK_TEST-)
#
# KWA PRODUCTION (pesa za kweli):
# ─────────────────────────────────
# 1. Kamilisha KYC verification kwenye dashboard
# 2. Badilisha na "Live Secret Key" (FLWSECK-...)
#
FLW_SECRET_KEY=your_test_secret_key_hapa
FLW_PUBLIC_KEY=your_test_public_key_hapa
FLW_BASE_URL=https://api.flutterwave.com/v3

# URL ambayo Flutterwave itatuma webhook ya matokeo ya malipo
# Kwa production lazima iwe URL ya kweli (si localhost)
# Tumia ngrok kwa majaribio: https://ngrok.com/download
# Mfano: FLW_REDIRECT_URL=https://abc123.ngrok-free.dev/api/payment/callback
FLW_REDIRECT_URL=http://localhost:3001/api/payment/callback

# Secret Hash kwa kuthibitisha webhook (Settings > Webhooks kwenye dashboard)
FLW_WEBHOOK_HASH=your_webhook_secret_hash_hapa
