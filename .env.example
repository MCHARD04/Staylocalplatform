# ════════════════════════════════════════════════════════
#   STAYLOCAL - ENVIRONMENT VARIABLES
#   Copy this file to .env and fill in your real values
#   Command: copy .env.example .env
# ════════════════════════════════════════════════════════

# ─── SERVER ──────────────────────────────────────────────
PORT=3001

# ─── AZAMPESA PAYMENT GATEWAY ────────────────────────────
#
# HATUA ZA KUPATA CREDENTIALS:
# ─────────────────────────────
# 1. Nenda: https://www.azampesa.co.tz
# 2. Bonyeza "Become a Merchant" au "Jiunge kama Merchant"
# 3. Jaza fomu:
#    - Business Name (jina la biashara yako)
#    - Business Type (e.g. Online Services / Real Estate)
#    - TIN Number (Tax Identification Number)
#    - NIN / Passport ya mmiliki
#    - Phone Number ya biashara
#    - Email ya biashara
# 4. Subiri approval - kwa kawaida siku 1-3 za kazi
# 5. Baada ya approval, login kwenye merchant portal:
#    https://merchant.azampesa.co.tz
# 6. Nenda: Settings > API Credentials
# 7. Nakili credentials zako hapa chini
#
# KWA MAJARIBIO (SANDBOX - bila pesa za kweli):
# ─────────────────────────────────────────────
# Pata sandbox credentials kwa kuwasiliana na:
# Email: developer@azampesa.co.tz
# Au nenda: https://sandbox.azampesa.co.tz
#
AZAM_APP_NAME=StayLocal
AZAM_CLIENT_ID=your_client_id_hapa
AZAM_CLIENT_SECRET=your_client_secret_hapa
AZAM_VENDOR_ID=your_vendor_id_hapa

# Sandbox URLs (mbili tofauti - authentication na checkout ni tofauti)
AZAM_AUTH_URL=https://authenticator-sandbox.azampay.co.tz
AZAM_CHECKOUT_URL=https://sandbox.azampay.co.tz

# URL ambayo AzamPesa itatuma matokeo ya malipo
# Kwa production lazima iwe URL ya kweli (si localhost)
# Tumia ngrok kwa majaribio: https://ngrok.com/download
# Mfano: AZAM_CALLBACK_URL=https://abc123.ngrok.io/api/payment/callback
AZAM_CALLBACK_URL=http://localhost:3001/api/payment/callback
